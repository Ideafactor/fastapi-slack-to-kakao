# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/fastapi_slack

# Redis
REDIS_URL=redis://localhost:6379/0

# Kakao
KAKAO_ADMIN_KEY=your_kakao_admin_key_here
KAKAO_API_URL=https://your-cstalk-api-url.com

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Triage channel for rate limit fallback
SLACK_TRIAGE_CHANNEL_ID=C0000000000

# AWS S3 (대용량 파일 fallback)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=your-bucket-name
S3_PUBLIC_BASE_URL=https://your-bucket.s3.ap-northeast-2.amazonaws.com
